# --- Go ----------------------------------------------------------------
# Compiled binaries (we don't commit prebuilt binaries; users `go build`).
metrics-monitor
metrics-monitor.exe
*.test
*.prof
coverage.out
coverage.html

# Vendor dir if anyone runs `go mod vendor` locally. The module root
# lives at source/, so vendor would land at source/vendor/.
/source/vendor/

# --- OS / editors ------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# --- Local runtime ----------------------------------------------------
# Logs / temp output a user might capture while developing.
/tmp/
*.log

# Local config overrides (the canonical config is
# source/etc/metrics-monitor.toml, which is committed; ad-hoc
# overrides for local testing go here).
source/etc/local.toml
source/etc/*.local.toml
